<?xml version="1.0" encoding="utf-8"?>
<!--
     This configuration file is required for Node.js applications to run on Microsoft Azure App Service
-->
<configuration>
  <system.webServer>
    <!-- Main Node.js application endpoint -->
    <webSocket enabled="false" />
    <handlers>
      <!-- Indicates that the server.js file is a node.js site to be handled by the iisnode module -->
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <!-- Make sure we don't hide the iisnode.js file or serve the logs -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^server.js\/debug[\/]?" />
        </rule>
        
        <!-- First we consider whether the incoming URL matches a physical file in the /public folder -->
        <rule name="StaticContent" stopProcessing="true">
          <match url="^([\\/]Admin[\\/].*)$|^([\\/]images[\\/].*)$" />
          <action type="Rewrite" url="public{R:1}" logRewrittenUrl="true" />
        </rule>
        
        <!-- All other URLs are mapped to the Node.js site entry point -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True" />
          </conditions>
          <action type="Rewrite" url="server.js" logRewrittenUrl="true" />
        </rule>
      </rules>
    </rewrite>
    
    <!-- You can change this to resumeUrl in production mode -->
    <security>
      <requestFiltering>
        <fileExtensions>
          <add fileExtension=".json" allowed="true" />
        </fileExtensions>
      </requestFiltering>
    </security>
    
    <!-- Management of user sessions
    <webSocket enabled="true" receiveBufferLimit="0" />
    -->
  </system.webServer>
  
  <!-- Configuration for Node.js iisnode module -->
  <iisnode 
    nodeProcessCommandLine="D:\Program Files (x86)\nodejs\node.exe"
    interceptor="D:\Program Files (x86)\iisnode\interceptor.js"
  />
</configuration>
